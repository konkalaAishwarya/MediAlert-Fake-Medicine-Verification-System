<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>PharmaVerify — Pharmaceutical Authenticity System</title>

<link rel="preconnect" href="https://fonts.googleapis.com">

<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>

:root {

  --bg: #0a0d12;

  --bg2: #0f1319;

  --bg3: #141922;

  --surface: #1a2030;

  --surface2: #202736;

  --border: rgba(255,255,255,0.07);

  --border2: rgba(255,255,255,0.12);

  --text: #e8edf5;

  --text2: #8a94a6;

  --text3: #5a6478;

  --accent: #00d4aa;

  --accent2: #00a882;

  --danger: #ff4757;

  --danger2: #cc2233;

  --warning: #ffaa00;

  --info: #4a9eff;

  --green: #00c471;

  --purple: #8b5cf6;

  --font-display: 'Syne', sans-serif;

  --font-body: 'DM Sans', sans-serif;

  --font-mono: 'DM Mono', monospace;

  --radius: 8px;

  --radius-lg: 14px;

  --radius-xl: 20px;

}

, ::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body { font-family: var(--font-body); background: var(--bg); color: var(--text); min-height: 100vh; overflow-x: hidden; }

/* ===== SCROLLBAR ===== */

::-webkit-scrollbar { width: 4px; }

::-webkit-scrollbar-track { background: var(--bg); }

::-webkit-scrollbar-thumb { background: var(--surface2); border-radius: 4px; }

/* ===== PAGES ===== */

.page { display: none; min-height: 100vh; }

.page.active { display: flex; flex-direction: column; }

/* ===== GRID BACKGROUND ===== */

.grid-bg {

  position: fixed; inset: 0; pointer-events: none; z-index: 0;

  background-image: linear-gradient(rgba(0,212,170,0.03) 1px, transparent 1px),

    linear-gradient(90deg, rgba(0,212,170,0.03) 1px, transparent 1px);

  background-size: 40px 40px;

}

.glow-orb {

  position: fixed; border-radius: 50%; filter: blur(120px); pointer-events: none; z-index: 0;

}

.glow-1 { width: 500px; height: 500px; background: rgba(0,212,170,0.06); top: -100px; right: -100px; }

.glow-2 { width: 400px; height: 400px; background: rgba(74,158,255,0.04); bottom: -50px; left: -100px; }

/* ===== TYPOGRAPHY ===== */

h1, h2, h3, h4 { font-family: var(--font-display); }

.display { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.02em; }

.mono { font-family: var(--font-mono); }

/* ===== COMPONENTS ===== */

.btn {

  display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px;

  border-radius: var(--radius); font-family: var(--font-body); font-size: 14px;

  font-weight: 500; cursor: pointer; transition: all 0.2s; border: none; text-decoration: none;

}

.btn-primary { background: var(--accent); color: #000; }

.btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }

.btn-danger { background: var(--danger); color: #fff; }

.btn-danger:hover { background: var(--danger2); }

.btn-outline { background: transparent; border: 1px solid var(--border2); color: var(--text); }

.btn-outline:hover { background: var(--surface); border-color: var(--accent); color: var(--accent); }

.btn-ghost { background: transparent; border: none; color: var(--text2); }

.btn-ghost:hover { color: var(--text); }

.btn-full { width: 100%; justify-content: center; }

.btn-lg { padding: 14px 28px; font-size: 16px; }

.card {

  background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem;

}

.card-sm { padding: 1rem; border-radius: var(--radius); }

input, select, textarea {

  width: 100%; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius);

  padding: 10px 14px; color: var(--text); font-family: var(--font-body); font-size: 14px;

  transition: border-color 0.2s; outline: none;

}

input:focus, select:focus, textarea:focus { border-color: var(--accent); }

input::placeholder, textarea::placeholder { color: var(--text3); }

select option { background: var(--bg2); }

label { display: block; font-size: 12px; font-weight: 500; color: var(--text2); margin-bottom: 6px; letter-spacing: 0.04em; text-transform: uppercase; }

.badge {

  display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px;

  border-radius: 20px; font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;

}

.badge-green { background: rgba(0,196,113,0.12); color: var(--green); border: 1px solid rgba(0,196,113,0.25); }

.badge-red { background: rgba(255,71,87,0.12); color: var(--danger); border: 1px solid rgba(255,71,87,0.25); }

.badge-amber { background: rgba(255,170,0,0.12); color: var(--warning); border: 1px solid rgba(255,170,0,0.25); }

.badge-blue { background: rgba(74,158,255,0.12); color: var(--info); border: 1px solid rgba(74,158,255,0.25); }

.badge-teal { background: rgba(0,212,170,0.12); color: var(--accent); border: 1px solid rgba(0,212,170,0.25); }

.badge-purple { background: rgba(139,92,246,0.12); color: var(--purple); border: 1px solid rgba(139,92,246,0.25); }

.badge-dot::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; display: inline-block; }

.divider { height: 1px; background: var(--border); margin: 1rem 0; }

.alert { padding: 12px 16px; border-radius: var(--radius); font-size: 14px; margin-bottom: 1rem; border-left: 3px solid; }

.alert-danger { background: rgba(255,71,87,0.08); color: #ff8a94; border-color: var(--danger); }

.alert-success { background: rgba(0,196,113,0.08); color: #5de8a5; border-color: var(--green); }

.alert-info { background: rgba(74,158,255,0.08); color: #7ab8ff; border-color: var(--info); }

.alert-warn { background: rgba(255,170,0,0.08); color: #ffc940; border-color: var(--warning); }

.stat-card {

  background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem;

}

.stat-num { font-family: var(--font-display); font-size: 2rem; font-weight: 700; margin-top: 6px; }

.hidden { display: none !important; }

.flex { display: flex; }

.flex-center { display: flex; align-items: center; }

.gap-2 { gap: 8px; }

.gap-3 { gap: 12px; }

.gap-4 { gap: 16px; }

.grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

.grid4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

.mb-1 { margin-bottom: 8px; }

.mb-2 { margin-bottom: 16px; }

.mb-3 { margin-bottom: 24px; }

.mt-1 { margin-top: 8px; }

.mt-2 { margin-top: 16px; }

.text-muted { color: var(--text2); }

.text-sm { font-size: 13px; }

.text-xs { font-size: 12px; }

.fw-500 { font-weight: 500; }

.tag { font-family: var(--font-mono); font-size: 12px; color: var(--text3); }

/* ===== LANDING PAGE ===== */

.landing-nav {

  position: fixed; top: 0; left: 0; right: 0; z-index: 100;

  padding: 0 2rem; height: 64px;

  display: flex; align-items: center; justify-content: space-between;

  border-bottom: 1px solid var(--border);

  background: rgba(10,13,18,0.8); backdrop-filter: blur(20px);

}

.logo { font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--accent); letter-spacing: -0.01em; display: flex; align-items: center; gap: 10px; }

.logo-icon { width: 32px; height: 32px; background: var(--accent); border-radius: 8px; display: flex; align-items: center; justify-content: center; }

.hero { padding: 10rem 2rem 6rem; max-width: 900px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }

.hero-tag { display: inline-flex; align-items: center; gap: 8px; background: rgba(0,212,170,0.08); border: 1px solid rgba(0,212,170,0.2); border-radius: 20px; padding: 6px 14px; font-size: 12px; color: var(--accent); font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 2rem; }

.hero-tag::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: pulse 2s infinite; }

@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

.hero-sub { font-size: 1.2rem; color: var(--text2); margin: 1.5rem auto; max-width: 600px; line-height: 1.6; font-weight: 300; }

.hero-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 2.5rem; }

.features-section { padding: 5rem 2rem; max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }

.section-label { font-family: var(--font-mono); font-size: 12px; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1rem; }

.section-title { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 700; margin-bottom: 1rem; }

.features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: var(--radius-xl); overflow: hidden; margin-top: 3rem; }

.feature-item { background: var(--bg); padding: 2rem; transition: background 0.2s; }

.feature-item:hover { background: var(--bg2); }

.feature-icon { width: 40px; height: 40px; border-radius: var(--radius); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }

.feature-title { font-family: var(--font-display); font-size: 16px; font-weight: 600; margin-bottom: 8px; }

.feature-desc { font-size: 14px; color: var(--text2); line-height: 1.6; }

.stats-bar { background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 2.5rem 2rem; }

.stats-inner { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; text-align: center; }

.stat-item-num { font-family: var(--font-display); font-size: 2.2rem; font-weight: 800; color: var(--accent); }

.stat-item-label { font-size: 13px; color: var(--text2); margin-top: 4px; }

.roles-section { padding: 5rem 2rem; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }

.roles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 2.5rem; }

.role-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem; cursor: pointer; transition: all 0.2s; position: relative; overflow: hidden; }

.role-card::after { content: ''; position: absolute; inset: 0; border-radius: var(--radius-lg); border: 1px solid transparent; transition: border-color 0.2s; }

.role-card:hover { background: var(--surface2); transform: translateY(-2px); }

.role-card:hover::after { border-color: var(--accent); }

.role-card-icon { font-size: 24px; margin-bottom: 10px; }

.role-card-title { font-family: var(--font-display); font-size: 15px; font-weight: 600; margin-bottom: 4px; }

.role-card-desc { font-size: 12px; color: var(--text2); }

.landing-footer { padding: 2rem; text-align: center; border-top: 1px solid var(--border); color: var(--text3); font-size: 13px; position: relative; z-index: 1; }

/* ===== LOGIN PAGE ===== */

.login-page { min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; }

.login-left { background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 3rem; position: relative; overflow: hidden; }

.login-left-content { max-width: 420px; width: 100%; position: relative; z-index: 1; }

.login-right { display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 3rem; }

.login-form-wrap { max-width: 400px; width: 100%; }

.login-art { position: absolute; inset: 0; overflow: hidden; }

.login-art-circle { position: absolute; border-radius: 50%; border: 1px solid rgba(0,212,170,0.1); }

.form-group { margin-bottom: 1.25rem; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

/* ===== APP LAYOUT ===== */

.app-layout { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }

.sidebar {

  background: var(--bg2); border-right: 1px solid var(--border);

  display: flex; flex-direction: column; position: fixed; left: 0; top: 0; bottom: 0; width: 240px; z-index: 50;

}

.sidebar-logo { padding: 1.25rem 1.25rem 1rem; border-bottom: 1px solid var(--border); }

.sidebar-nav { flex: 1; padding: 1rem 0.75rem; overflow-y: auto; }

.sidebar-section-label { font-size: 10px; font-weight: 600; color: var(--text3); letter-spacing: 0.1em; text-transform: uppercase; padding: 0 0.75rem; margin: 1rem 0 0.5rem; }

.nav-item {

  display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: var(--radius);

  font-size: 14px; color: var(--text2); cursor: pointer; transition: all 0.15s; margin-bottom: 2px;

  border: none; background: transparent; width: 100%; text-align: left;

}

.nav-item:hover { background: var(--surface); color: var(--text); }

.nav-item.active { background: rgba(0,212,170,0.1); color: var(--accent); font-weight: 500; }

.nav-item-icon { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.7; }

.nav-item.active .nav-item-icon { opacity: 1; }

.sidebar-footer { padding: 1rem; border-top: 1px solid var(--border); }

.user-chip { display: flex; align-items: center; gap: 10px; padding: 10px; border-radius: var(--radius); background: var(--surface); }

.avatar { width: 32px; height: 32px; border-radius: 50%; background: rgba(0,212,170,0.15); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 12px; font-weight: 700; color: var(--accent); flex-shrink: 0; }

.avatar-lg { width: 48px; height: 48px; font-size: 16px; }

.user-name { font-size: 13px; font-weight: 500; }

.user-role { font-size: 11px; color: var(--text2); }

.main-content { margin-left: 240px; flex: 1; }

.topbar {

  height: 60px; background: var(--bg2); border-bottom: 1px solid var(--border);

  display: flex; align-items: center; justify-content: space-between;

  padding: 0 2rem; position: sticky; top: 0; z-index: 40;

}

.page-title { font-family: var(--font-display); font-size: 18px; font-weight: 600; }

.content-area { padding: 2rem; }

/* ===== SCAN PAGE ===== */

.scan-zone {

  background: var(--bg2); border: 2px dashed var(--border2); border-radius: var(--radius-xl);

  padding: 2rem; text-align: center; transition: border-color 0.2s;

}

.scan-zone.active { border-color: var(--accent); }

#cam-video { width: 100%; border-radius: var(--radius-lg); border: 1px solid var(--border); max-height: 320px; object-fit: cover; display: none; }

#cam-canvas { display: none; }

.scan-result-card { border-radius: var(--radius-lg); padding: 2rem; text-align: center; margin-top: 1.5rem; border: 1px solid; }

.result-real { background: rgba(0,196,113,0.06); border-color: rgba(0,196,113,0.3); }

.result-fake { background: rgba(255,71,87,0.06); border-color: rgba(255,71,87,0.3); }

.result-unclear { background: rgba(255,170,0,0.06); border-color: rgba(255,170,0,0.3); }

.result-icon { font-size: 3rem; margin-bottom: 1rem; }

.result-verdict { font-family: var(--font-display); font-size: 2rem; font-weight: 800; }

/* ===== FAKE DETAIL ===== */

.fake-detail-header { background: linear-gradient(135deg, rgba(255,71,87,0.15) 0%, transparent 60%); border-bottom: 1px solid var(--border); padding: 2rem; }

.reporter-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 1.5rem; }

.reporter-field { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem; }

.reporter-field-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text3); margin-bottom: 6px; }

.reporter-field-value { font-size: 15px; font-weight: 500; }

.last-mile-steps { display: flex; flex-direction: column; gap: 12px; }

.last-mile-step { display: flex; gap: 14px; align-items: flex-start; padding: 14px; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); }

.step-num { width: 28px; height: 28px; border-radius: 50%; background: rgba(255,71,87,0.15); color: var(--danger); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; flex-shrink: 0; font-family: var(--font-display); }

/* ===== NEWS ===== */

.news-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 1rem; }

.news-header { background: linear-gradient(90deg, rgba(255,71,87,0.1) 0%, transparent 100%); border-bottom: 1px solid var(--border); padding: 1.25rem; border-left: 4px solid var(--danger); }

.news-body { padding: 1.25rem; }

/* ===== TABLE ===== */

table { width: 100%; border-collapse: collapse; }

thead tr { border-bottom: 1px solid var(--border); }

th { text-align: left; padding: 10px 12px; font-size: 11px; font-weight: 600; color: var(--text3); letter-spacing: 0.05em; text-transform: uppercase; }

tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }

tbody tr:last-child { border: none; }

tbody tr:hover { background: var(--surface); }

td { padding: 12px; font-size: 13px; }

/* ===== CHAIN VIZ ===== */

.chain-step { display: flex; align-items: center; gap: 0; }

.chain-node { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 16px; flex: 1; }

.chain-arrow { color: var(--text3); padding: 0 8px; font-size: 18px; }

/* ===== RECALL ===== */

.recall-urgent { background: linear-gradient(135deg, rgba(255,71,87,0.12), rgba(255,71,87,0.04)); border: 1px solid rgba(255,71,87,0.3); border-radius: var(--radius-xl); padding: 2rem; margin-bottom: 1.5rem; }

/* ===== ANIMATIONS ===== */

@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

.fade-in { animation: fadeIn 0.4s ease forwards; }

@keyframes slideIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }

@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

.spinner { width: 20px; height: 20px; border: 2px solid var(--border2); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; }

/* ===== RESPONSIVE ===== */

@media (max-width: 900px) {

  .login-page { grid-template-columns: 1fr; }

  .login-left { display: none; }

  .app-layout { grid-template-columns: 1fr; }

  .sidebar { display: none; }

  .main-content { margin-left: 0; }

  .grid3, .reporter-grid, .grid4 { grid-template-columns: 1fr; }

  .roles-grid { grid-template-columns: 1fr 1fr; }

  .stats-inner { grid-template-columns: 1fr 1fr; }

  .features-grid { grid-template-columns: 1fr; }

}

/* SVG ICONS inline */

.icon { display: inline-block; }

</style>

</head>

