        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>

        Initiate recall

      </button>

      <button class="btn btn-outline" onclick="showToast('fd-action')">Flag to CDSCO regulator</button>

      <button class="btn btn-ghost" onclick="showToast('fd-action')">Download PDF report</button>

      <div id="toast-fd-action" class="alert alert-success hidden" style="width:100%;margin-top:.5rem">Action taken. Regulators in ${f.location} notified within 60 seconds. Batch flagged system-wide.</div>

    </div>

  </div>`;

}

/* ============================

   CAMERA & AI SCAN

   ============================ */

function startCamera() {

  navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })

    .then(stream => {

      cameraStream = stream;

      const v = document.getElementById('cam-video');

      const p = document.getElementById('cam-placeholder');

      if (v && p) { v.srcObject = stream; v.style.display = 'block'; p.style.display = 'none'; document.querySelector('.scan-zone')?.classList.add('active'); }

    })

    .catch(() => alert('Camera access denied. Please use manual entry below.'));

}

function stopCamera() {

  if (cameraStream) { cameraStream.getTracks().forEach(t => t.stop()); cameraStream = null; }

  const v = document.getElementById('cam-video');

  const p = document.getElementById('cam-placeholder');

  if (v) v.style.display = 'none';

  if (p) p.style.display = 'block';

}

async function captureAndVerify() {

  const v = document.getElementById('cam-video');

  const c = document.getElementById('cam-canvas');

  if (!cameraStream) { alert('Open the camera first.'); return; }

  c.width = v.videoWidth || 640; c.height = v.videoHeight || 480;

  c.getContext('2d').drawImage(v, 0, 0);

  const imgData = c.toDataURL('image/jpeg', 0.75);

  showScanLoading();

  try {

    const b64 = imgData.split(',')[1];

    const res = await fetch('https://api.anthropic.com/v1/messages', {

      method: 'POST', headers: { 'Content-Type': 'application/json' },

      body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 1000,

        messages: [{ role: 'user', content: [

          { type: 'image', source: { type: 'base64', media_type: 'image/jpeg', data: b64 } },

          { type: 'text', text: 'You are a pharmaceutical verification AI. Analyze this image of a medicine/drug package or label. Look for signs of authenticity or counterfeiting: print quality, font consistency, hologram indicators, batch code format, spelling errors, packaging material quality, color accuracy. Respond ONLY in JSON (no markdown, no fences): {"verdict":"REAL" or "FAKE" or "UNCLEAR","medicine":"name if visible or Unknown","confidence":"High or Medium or Low","reason":"1-2 sentence analysis","warning":"next step for user (1 sentence)","indicators":["indicator 1","indicator 2","indicator 3"]}' }

        ]}]

      })

    });

    const d = await res.json();

    const txt = d.content.map(i => i.text || '').join('');

    const parsed = JSON.parse(txt.replace(/```json|```/g, '').trim());

    showScanResult(parsed);

  } catch(e) {

    showScanResult({ verdict: 'UNCLEAR', medicine: 'Unknown', confidence: 'Low', reason: 'Could not analyze the image. Ensure good lighting and the label is clearly visible.', warning: 'Try again or use manual entry below.', indicators: [] });

  }

}

async function verifyManual() {

  const name = document.getElementById('m-name')?.value;

  const batch = document.getElementById('m-batch')?.value;

  const mfr = document.getElementById('m-mfr')?.value;

  if (!name && !batch) { alert('Enter at least a medicine name or batch ID.'); return; }

  showScanLoading();

  try {

    const res = await fetch('https://api.anthropic.com/v1/messages', {

      method: 'POST', headers: { 'Content-Type': 'application/json' },

      body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 800,

        messages: [{ role: 'user', content: You are a pharmaceutical verification AI. Verify this medicine: Name="${name}", Batch="${batch}", Manufacturer="${mfr}". Assess based on: known manufacturer names, legitimate batch ID formats (typically MANUFACTURER-YEAR-SERIES), drug naming conventions, and known counterfeit patterns. Respond ONLY in JSON (no markdown): {"verdict":"REAL" or "FAKE" or "UNCLEAR","medicine":"${name||'Unknown'}","confidence":"High or Medium or Low","reason":"1-2 sentence analysis","warning":"one sentence next step for user","indicators":["check 1","check 2","check 3"]} }]

      })

    });

    const d = await res.json();

    const txt = d.content.map(i => i.text || '').join('');

    const parsed = JSON.parse(txt.replace(/```json|```/g, '').trim());

    showScanResult(parsed);

  } catch(e) {

    showScanResult({ verdict: 'UNCLEAR', medicine: name || 'Unknown', confidence: 'Low', reason: 'Verification service unavailable. Please try again.', warning: 'Contact your pharmacist for manual verification.', indicators: [] });

  }

}

function showScanLoading() {

  document.getElementById('scan-result-box').innerHTML = `

  <div style="display:flex;align-items:center;gap:12px;padding:1.5rem;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);margin-top:1rem">

    <div class="spinner"></div>

    <div>

      <div style="font-size:14px;font-weight:500">Analysing medicine...</div>

      <div class="text-xs text-muted">AI verification in progress</div>

    </div>

  </div>`;

}

function showScanResult(data) {

  const isFake = data.verdict === 'FAKE';

  const isReal = data.verdict === 'REAL';

  const cls = isFake ? 'result-fake' : isReal ? 'result-real' : 'result-unclear';

  const col = isFake ? 'var(--danger)' : isReal ? 'var(--green)' : 'var(--warning)';

  const icon = isFake ? '⚠️' : isReal ? '✅' : '❓';

  const indicators = data.indicators?.length ? <div style="margin-top:1rem;display:flex;flex-direction:column;gap:6px">${data.indicators.map(i=><div style="display:flex;align-items:center;gap:8px;font-size:13px;text-align:left"><span style="width:6px;height:6px;border-radius:50%;background:${col};flex-shrink:0"></span>${i}</div).join('')}</div> : '';

  const reportBtn = isFake ? <button class="btn btn-danger" style="margin-top:1rem" onclick="showToast('report-sent')">Report to authorities</button><div id="toast-report-sent" class="alert alert-success hidden" style="margin-top:.5rem;text-align:left">Report filed. Health authorities and pharmacies in your area notified.</div> : '';

  document.getElementById('scan-result-box').innerHTML = `

  <div class="scan-result-card ${cls}" style="margin-top:1rem">

    <div class="result-icon">${icon}</div>

    <div class="result-verdict" style="color:${col}">${data.verdict}</div>

    <div class="text-sm text-muted" style="margin-top:6px">${data.medicine} · Confidence: ${data.confidence}</div>

    <div style="font-size:14px;margin-top:1rem;line-height:1.6">${data.reason}</div>

    <div style="font-size:13px;font-weight:500;color:${col};margin-top:.5rem">${data.warning}</div>

    ${indicators}

    ${reportBtn}

  </div>`;

}

/* ============================

   UTILS

   ============================ */

function showToast(id) {

  const el = document.getElementById('toast-' + id);

  if (el) { el.classList.remove('hidden'); el.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }

}

function showCheckinResult() {

  document.getElementById('ci-result').classList.remove('hidden');

  document.getElementById('ci-result').scrollIntoView({ behavior: 'smooth' });

}

</script>

